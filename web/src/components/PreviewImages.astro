---
import { Image } from 'astro:assets';
import { getAssetImagePath } from '@src/utils/general';
import MicroModalInit from '@src/components/MicroModalInit.astro';

interface Props {
  images?: any;
}

let { images } = Astro.props;

// Assign id to each image for modal functionality
images = images.map((imageInfo: any, index: number) => {
    return {
        ...imageInfo,
        id: `image-modal-${index}`,
    };
});
---

{images && images.length > 0 && (
    <div class="preview-images">
        {images.map((imageInfo: any) => (
            <a href="#" >
                <Image width={imageInfo.width || undefined}
                    height={imageInfo.height || undefined}
                    src={getAssetImagePath(imageInfo.path)}
                    alt={imageInfo.description || "Preview"}
                    style="cursor: zoom-in; max-width: 200px;" data-micromodal-trigger={imageInfo.id} />
            </a>

            <div class="modal micromodal-slide" id={imageInfo.id} aria-hidden="true">
                <div class="modal__overlay" tabindex="-1" data-micromodal-close>
                    <div class="modal__container" role="dialog" aria-modal="true" aria-labelledby={`${imageInfo.id}-title`}>
                        <header class="modal__header">
                            <button class="modal__close" aria-label="Close modal" data-micromodal-close>&times;</button>
                        </header>
                        <main class="modal__content">
                            <Image
                                src={getAssetImagePath(imageInfo.path)}
                                alt={imageInfo.description || "Preview"}
                                class="modal__image" />
                        </main>
                    </div>
                </div>
            </div>
        ))}
    </div>
)}

<MicroModalInit />